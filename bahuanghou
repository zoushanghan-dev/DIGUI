#include<iostream>
#include<algorithm>
using namespace std;
struct Ans {
	int queen[8];
	int total;
};
Ans ans[92];
int temp[8] = { 0 };
bool safe(int row, int col) {
	for (int i = 0; i < row; i++) {
		if (temp[i] == col || abs(temp[i] - col) == abs(i - row)) {
			return false;
		}
	}
	return true;
}
int k = 0;
void solve(int row){
	if (row == 8) {
			ans[k].total = 0;
		for (int j = 0; j < 8; j++) {
			ans[k].queen[j] = temp[j];
			ans[k].total += temp[j];
		}
		k++;
		return;
	}
	for (int col = 1; col < 9; col++) {
		if (safe(row, col)) {
			temp[row] = col;
			solve(row + 1);
		}
	}
}
bool cmp(const Ans& a, const Ans& b) {
	return a.total < b.total;
}
int main() {
	solve(0);
	sort(ans, ans + 92, cmp);
	int num;
	cin >> num;
	for (int j = 0; j = num; j++) {
		int a;
		cin >> a;
		for (int i = 0; i < 8; i++) {
			cout << ans[a-1].queen[i];
		}
	}
	cout << endl;
}
